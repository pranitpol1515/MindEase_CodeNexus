## Backend environment variables
#
# Create `backend/.env` (same folder as `backend/main.py`) and set ONE of these:
#
# GOOGLE_API_KEY=your_key_here
# GEMINI_API_KEY=your_key_here
#
# Do NOT commit `backend/.env` to git.

GOOGLE_API_KEY=
GEMINI_API_KEY=

# Optional: if 8080 is blocked on your machine
PORT=8080
